# Keystore Configuration for Release Build
# Copy this file to keystore.properties and fill in your actual values
# IMPORTANT: Do NOT commit keystore.properties to version control!

# Path to your keystore file (relative to app/ directory)
STORE_FILE=../keystore.jks

# Keystore password
STORE_PASSWORD=your_keystore_password

# Key alias
KEY_ALIAS=pdftools

# Key password
KEY_PASSWORD=your_key_password
